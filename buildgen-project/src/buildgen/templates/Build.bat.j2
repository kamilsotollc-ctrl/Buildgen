@echo off
setlocal enabledelayedexpansion

rem Auto-generated by buildgen. Do not edit by hand -- edit build.yaml instead.

set STEP=%1
if "%STEP%"=="" set STEP=all

if "%STEP%"=="all" goto :do_all
if "%STEP%"=="configure" goto :do_configure
if "%STEP%"=="build" goto :do_build
if "%STEP%"=="test" goto :do_test
if "%STEP%"=="install" goto :do_install

echo Unknown step: %STEP%
echo Usage: Build.bat [all^|configure^|build^|test^|install]
exit /b 1

:do_all
call :configure
if errorlevel 1 exit /b 1
call :build
if errorlevel 1 exit /b 1
exit /b 0

:do_configure
call :configure
exit /b %errorlevel%

:do_build
call :build
exit /b %errorlevel%

:do_test
call :test
exit /b %errorlevel%

:do_install
call :install
exit /b %errorlevel%

:configure
{% for cmd in configure %}
{{ cmd }}
if errorlevel 1 exit /b 1
{% endfor %}
{% if not configure %}
echo (no configure step defined)
{% endif %}
exit /b 0

:build
{% for cmd in build %}
{{ cmd }}
if errorlevel 1 exit /b 1
{% endfor %}
{% if not build %}
echo (no build step defined)
{% endif %}
exit /b 0

:test
{% for cmd in test %}
{{ cmd }}
if errorlevel 1 exit /b 1
{% endfor %}
{% if not test %}
echo (no test step defined)
{% endif %}
exit /b 0

:install
{% for cmd in install %}
{{ cmd }}
if errorlevel 1 exit /b 1
{% endfor %}
{% if not install %}
echo (no install step defined)
{% endif %}
exit /b 0
